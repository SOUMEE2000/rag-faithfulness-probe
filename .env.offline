# ── .env.offline ──────────────────────────────────────────────────────────────
# Copy this file to .env before running docker compose on an offline machine.
# Script 06_run_pipeline.bat does this automatically.
#
# These two variables tell the HuggingFace libraries to NEVER make network
# requests — they will fail fast with a clear error instead of hanging if a
# model or dataset is missing from the volume cache.

TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
